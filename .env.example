# PhantomShield AI — Optional API Keys
# Copy this file to ".env" and fill in any keys you have.
# Every module works WITHOUT these (offline heuristics) — keys just unlock live data.
#
# To load this file automatically, run:  pip install python-dotenv
# and add "from dotenv import load_dotenv; load_dotenv()" at the top of app.py
# (already commented in app.py — uncomment if you want .env support)

# VirusTotal — URL & file hash reputation. Free tier: virustotal.com/gui/join-us
VT_API_KEY=

# NVD — raises CVE search rate limit from 5/30s to 50/30s. Free: nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# AlienVault OTX — threat pulse lookups. Free: otx.alienvault.com (sign up, copy API key from settings)
OTX_API_KEY=

# AbuseIPDB — IP abuse confidence scoring. Free tier: abuseipdb.com/account/api
ABUSEIPDB_KEY=

# Groq — powers the full AI Security Assistant (LLaMA 3.3 70B). Free: console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Flask session secret — change this to any random string for production
SECRET_KEY=phantomshield-dev-key-change-me
